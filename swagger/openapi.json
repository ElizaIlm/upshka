            "description": "Статистика ресторана",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "dishes_total":  { "type": "integer" },
                    "orders_today":  { "type": "integer" },
                    "orders_total":  { "type": "integer" },
                    "clients_total": { "type": "integer" },
                    "waiters_total": { "type": "integer" },
                    "revenue_today": { "type": "number" },
                    "revenue_month": { "type": "number" }
                  }
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "403": { "$ref": "#/components/responses/Forbidden" }
        }
      }
